{
  "manifest_version": 3,
  "name": "AI HOT Notifier",
  "version": "1.0.17",
  "description": "随时感知 AI 前沿动态，桌面通知即时提醒，多主题随心切换，轻量不打扰。",
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["https://aihot.virxact.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
